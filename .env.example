# SENTINEL environment — copy to .env.local for local development.
#
# Demo mode (the default below) runs the ENTIRE app — dashboard, incidents, and
# AI — from a single entry with no sign-in and no cloud project. Add a Gemini API
# key to light up real AI; without one, every AI feature runs in deterministic
# rule-based mode. Nothing here is required just to see the app run.

# ── Gemini API key (server-only; never prefixed NEXT_PUBLIC_, never in the bundle)
# Create one at https://aistudio.google.com/apikey. Powers AI briefings, incident
# triage, and recommendation reasoning via gemini-3.5-flash. Absent → rule mode.
GEMINI_API_KEY=

# ── Demo mode ─────────────────────────────────────────────────────────────────
# AUTH_BYPASS=1 runs with no Firebase project: token verification is skipped and
# incidents are held in an in-memory store. This is how the Vercel demo runs. A
# test pins that a production request WITHOUT this flag is always rejected, so it
# is safe by construction — it only ever opens the door when explicitly set.
AUTH_BYPASS=1

# ── Firebase (optional; only to exercise REAL Google sign-in + Firestore) ──────
# Leave blank for demo mode. Fill from the Firebase console → Project settings →
# your web app → SDK config to run with real auth and persistence instead.
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
