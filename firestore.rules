rules_version = '2';

// SENTINEL Firestore rules.
//
// Deny everything, without exception.
//
// This is not a placeholder to be relaxed later. No client ever talks to
// Firestore directly: the browser sends an ID token to a Next.js route, the
// server verifies it with the Admin SDK, and only the server reads or writes.
// The Admin SDK bypasses these rules by design, so denying all client access
// costs the app nothing and removes the entire category of "someone found the
// collection and read every incident from the console".
//
// Incidents contain reports about identifiable people (a medical emergency, a
// lost child) written by staff under pressure. There is no read path that
// should exist outside an authenticated, audited server route.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
